{
  "name": "gitnexus-monorepo",
  "private": true,
  "workspaces": [
    "gitnexus",
    "gitnexus-web"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "build": "npm run build --workspace=gitnexus && npm run build --workspace=gitnexus-web",
    "build:server": "npm run build --workspace=gitnexus",
    "build:web": "npm run build --workspace=gitnexus-web",
    "start": "node gitnexus/dist/cli/index.js serve",
    "dev": "node gitnexus/dist/cli/index.js serve"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
