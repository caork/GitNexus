{
  "name": "gitnexus-monorepo",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix gitnexus && npm install --prefix gitnexus-web",
    "build": "npm run build --prefix gitnexus && npm run build --prefix gitnexus-web",
    "build:server": "npm run build --prefix gitnexus",
    "build:web": "npm run build --prefix gitnexus-web",
    "start": "node gitnexus/dist/cli/index.js serve",
    "dev": "node gitnexus/dist/cli/index.js serve",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,json,css,yml,yaml}": "prettier --write"
  }
}
